# ─────────────────────────────────────────
# K-Ride 프로젝트 .gitignore
# ─────────────────────────────────────────

# ── IDE ──
.idea/
.vscode/
*.iml

# ── OS ──
.DS_Store
Thumbs.db

# ── 환경변수 / 시크릿 ──
.env
.env.*
*.env
application-local.yml
subproject/SDUI/SDUI-server/src/main/resources/application-local.yml
assets/*.json
subproject/SDUI/pronounce-api/*.json

# ── Python / FastAPI ──
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
**/venv/
**/.venv/
.pytest_cache/
.coverage
*.egg-info/

# ── Spring Boot / Gradle ──
subproject/SDUI/SDUI-server/bin/
subproject/SDUI/SDUI-server/build/
subproject/SDUI/SDUI-server/target/
build/
.gradle/
out/
*.class
*.jar
*.war
*.ear

# ── Next.js / Node ──
node_modules/
subproject/SDUI/metadata-project/node_modules/
subproject/SDUI/metadata-project/.next/
subproject/SDUI/metadata-project/dist/
.next/
dist/

# ── 로그 ──
*.log
log.txt
logs/

# ── Playwright ──
test-results/
playwright-report/
trace.zip
video.webm
.last-run.json

# ── 이미지 (public 아이콘 제외) ──
*.png
!subproject/SDUI/metadata-project/public/**/*.png

# ── 기타 빌드 / 임시 파일 ──
*.tmp
*.bak
*.old
*.zip
*.tar.gz
*.pem
*.key
*.keystore
*.exe
*.dll
*.so
gradle/

# ── Claude Code ──
.claude
